rules_version = '2';

// CipherVault Firestore security rules.
//
// DEPLOY THESE. As shipped, the project was in "allow everyone" test mode:
// an unauthenticated request could read users/{anyUid} and pull down that
// user's encrypted vault, their salt, and their master-password verifier.
// Nothing stops an attacker enumerating or overwriting other people's vaults.
//
// Deploy with:   firebase deploy --only firestore:rules
// Or paste into: Firebase console -> Firestore Database -> Rules -> Publish
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // A signed-in user may only ever touch their own document.
      allow read, delete: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isValidVault(request.resource.data);

      // QR unlock handshake. Holds only two ephemeral ECDH public keys and a
      // ciphertext the server cannot open (see LinkSessionEngine), and both
      // devices must already be signed in as this same user. Documents are
      // single-use and deleted as soon as they have been consumed.
      match /linkSessions/{sessionId} {
        allow read, write, delete: if request.auth != null
          && request.auth.uid == userId
          && sessionId.size() <= 64;
      }
    }

    // Anything not matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidVault(data) {
    return data.keys().hasAll(['vault', 'salt', 'hash'])
      && data.vault is list
      && data.salt is string
      && data.hash is string
      && data.salt.size() > 0
      && data.hash.size() > 0
      // slKeyEnc is the SimpleLogin API key and foldersEnc is the folder list,
      // both encrypted client-side with the vault key. Optional, since vaults
      // written by earlier versions lack them.
      && (!('slKeyEnc' in data.keys()) || data.slKeyEnc is string)
      && (!('foldersEnc' in data.keys()) || data.foldersEnc is string)
      // Firestore caps a document at 1 MiB; reject anything near that so a
      // runaway client can't wedge the account into an unwritable state.
      && data.vault.size() <= 5000;
  }
}
