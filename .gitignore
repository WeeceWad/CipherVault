# Dependencies
node_modules/

# Build output
dist/
build/
out/
*.asar

# Android build output
.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
android/app/release/
android/app/debug/
*.apk
*.aab
*.aar

# Signing material - NEVER commit these.
# A leaked upload key lets somebody else publish updates as you, and losing it
# means every existing install has to be uninstalled before it can update.
.signing/
*.keystore
*.jks
keystore.properties
key.properties
google-services.json
service-account*.json

# Secrets
.env
.env.*
!.env.example

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Local scratch
tmp/
temp/

# Capacitor / Android generated native project artifacts
CipherVault-Android/android/local.properties
CipherVault-Android/android/.gradle/
CipherVault-Android/android/app/src/main/assets/public/
CipherVault-Android/android/app/src/main/assets/capacitor.config.json
CipherVault-Android/android/app/src/main/assets/capacitor.plugins.json
CipherVault-Android/android/capacitor-cordova-android-plugins/
# NOTE: CipherVault-Android/www/lib/ (the vendored Firebase SDKs) IS committed
# on purpose - CI cannot fetch it, and the app must not load scripts from a CDN.
