{
  "name": "ciphervault-desktop",
  "version": "1.0.0",
  "description": "CipherVault Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "electron test/e2e.js && electron test/qr.js && electron test/qr-ui.js && electron test/bridge.js",
    "build": "electron-builder --win",
    "test:vault": "electron test/e2e.js",
    "test:qr": "electron test/qr.js && electron test/qr-ui.js",
    "test:bridge": "electron test/bridge.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.ciphervault.desktop",
    "productName": "CipherVault",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "lib/**/*",
      "!test/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "artifactName": "CipherVault-Setup.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "WeeceWad",
        "repo": "CipherVault"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
