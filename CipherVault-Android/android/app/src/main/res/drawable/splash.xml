<?xml version="1.0" encoding="utf-8"?>
<!--
  Launch screen. A vector on the app's own dark background, so there is no
  white flash between tapping the icon and the WebView painting.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/cvBackground" />
    <item android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
